#############################################
# FASTAPI BACKEND CONFIG
#############################################
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

#############################################
# POSTGRES CONFIG (MUST MATCH docker-compose)
#############################################
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=ctdirp
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:change_me@localhost:5432/ctdirp

#############################################
# KAFKA CONFIG (optional; disabled unless KAFKA_ENABLED=true)
#############################################
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=ctdirp_events
KAFKA_GROUP=ctdirp_group

#############################################
# NOTIFICATION CONFIGURATION
#############################################
# Email alerts (use a provider app-password, never a real account password)
ALERT_EMAIL_FROM=you@example.com
ALERT_EMAIL_PASSWORD=your_smtp_app_password
ALERT_EMAIL_TO=alerts@example.com
ALERT_EMAIL_SMTP=smtp.gmail.com
ALERT_EMAIL_PORT=587

# Optional: Resend HTTP API (takes priority over SMTP if set)
RESEND_API_KEY=

# Slack / Telegram (optional)
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

#############################################
# JWT CONFIG
#############################################
# Generate a strong secret, e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRES=3600

#############################################
# CORS / FRONTEND
#############################################
# Comma-separated allowed origins for production
ALLOWED_ORIGINS=http://localhost:5173
# Optional regex for dynamic preview URLs
ALLOWED_ORIGINS_REGEX=
FRONTEND_URL=http://localhost:5173

#############################################
# LOGGING
#############################################
LOG_LEVEL=info
